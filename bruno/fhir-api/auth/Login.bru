meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Tamanu-Client: bruno
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}",
    "deviceId": "bruno-api-tester-device"
  }
}

script:post-response {
  if (res.body.token) {
    bru.setVar("token", res.body.token);
  }
}
