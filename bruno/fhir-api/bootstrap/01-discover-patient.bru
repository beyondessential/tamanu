meta {
  name: Discover Patient
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/integration/fhir/mat/Patient
  body: none
  auth: bearer
}

params:query {
  _count: 1
  _sort: -_lastUpdated
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const body = res.getBody && res.getBody();
  const id = body && body.entry && body.entry[0] && body.entry[0].resource && body.entry[0].resource.id;
  bru.setVar("patientId", id || "");
}

tests {

  test("Patient record found", function() {
    expect(bru.getVar("patientId"), "No Patient found in this environment").to.be.a("string").and.not.empty;
  });
}
