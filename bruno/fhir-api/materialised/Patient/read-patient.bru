meta {
  name: Read Patient
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/integration/fhir/mat/Patient/:id
  body: none
  auth: bearer
}

params:path {
  id: {{patientId}}
}

auth:bearer {
  token: {{token}}
}

docs {
  Defaults `:id` to `{{patientId}}` (set by `bootstrap/Discover Patient`).
}
