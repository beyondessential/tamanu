# Retry transient npm registry/network failures (CI runners hit these intermittently,
# e.g. ECONNRESET or 5xx mid-install). These tune npm's built-in fetch retry, so every
# npm command across the repo benefits without per-step wrapping. See `npm help npmrc`.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
