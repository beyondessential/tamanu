{
  "name": "tamanu",
  "version": "2.59.0",
  "description": "This repo contains all the packages for Tamanu",
  "homepage": "https://github.com/beyondessential/tamanu.git#readme",
  "repository": "git@github.com:beyondessential/tamanu.git",
  "author": "Beyond Essential Systems Pty. Ltd.",
  "license": "GPL-3.0-and-later AND BUSL-1.1",
  "type": "module",
  "scripts": {
    "prepare": "if [ -d node_modules/@react-pdf/textkit ]; then patch-package; fi",
    "clean": "npm run clean --workspaces --if-present",
    "clean:deps": "npm run clean:deps --workspaces --if-present && rimraf node_modules",
    "create-package": "node scripts/create-package.mjs",
    "create-migration": "node scripts/create-server-migration.mjs",
    "codemod:import-extensions": "node scripts/codemod-import-extensions.mjs",
    "codemod:lodash-imports": "node scripts/codemod-lodash-named-imports.mjs",
    "build": "turbo build",
    "clean-build": "turbo run clean-build --force",
    "test": "npm run build && node scripts/test-all.mjs",
    "test-coverage": "npm run test -- --coverage",
    "lint-all": "eslint .",
    "lint-fix": "npm run lint-all -- --fix",
    "admin-panel-start-dev": "npm run admin-start-dev --workspace @tamanu/web-frontend",
    "web-start-dev": "npm run client-start-dev --workspace @tamanu/web-frontend",
    "patient-portal-start-dev": "npm run start-dev --workspace @tamanu/patient-portal",
    "watch-shared-and": "node scripts/watch-shared-and.js",
    "web-unit-test": "turbo build --filter=@tamanu/web-frontend... && npm run --workspace @tamanu/web-frontend test",
    "web-unit-test-watch": "turbo build --filter=@tamanu/web-frontend... && npm run --workspace @tamanu/web-frontend test-watch",
    "facility-test": "turbo build --filter=@tamanu/facility-server... && npm run --workspace @tamanu/facility-server test",
    "facility-start-dev": "turbo build --filter=@tamanu/facility-server... && npm run watch-shared-and @tamanu/facility-server start-dev",
    "facility-test-watch": "npm run watch-shared-and @tamanu/facility-server test-watch",
    "facility-migrate": "turbo build --filter=@tamanu/facility-server... && npm run --workspace @tamanu/facility-server start-watch upgrade",
    "facility-migrate-down": "turbo build --filter=@tamanu/facility-server... && npm run --workspace @tamanu/facility-server start-watch just-migrate down",
    "mobile-run-android": "turbo build --filter=@tamanu/mobile^... && npm run --workspace @tamanu/mobile android",
    "shared-test": "turbo build --filter=@tamanu/shared... && npm run --workspace @tamanu/shared test",
    "central-test": "turbo build --filter=@tamanu/central-server... && npm run --workspace @tamanu/central-server test",
    "central-shell": "turbo build --filter=@tamanu/central-server... && npm run --workspace @tamanu/central-server shell",
    "central-start-dev": "turbo build --filter=@tamanu/central-server^... && npm run watch-shared-and @tamanu/central-server start-dev",
    "central-test-watch": "npm run watch-shared-and @tamanu/central-server test-watch",
    "central-start": "npm run central-start-dev",
    "central-migrate": "turbo build --filter=@tamanu/central-server... && npm run --workspace @tamanu/central-server start-watch upgrade",
    "central-migrate-down": "turbo build --filter=@tamanu/central-server... && npm run --workspace @tamanu/central-server start-watch just-migrate down",
    "build-report": "turbo build --filter=@tamanu/central-server && npm run --workspace @tamanu/central-server start report",
    "generate-migration-baseline": "npm run --workspace scripts build && npm run --workspace @tamanu/database build && NODE_CONFIG_DIR=packages/central-server/config node packages/scripts/dist/generateMigrationBaseline.js",
    "dbt-generate-model": "npm run --workspace scripts build && NODE_CONFIG_DIR=packages/central-server/config node packages/scripts/dist/dbt/generateModel.js",
    "dbt-generate-docs": "npm run --workspace scripts build && NODE_CONFIG_DIR=packages/central-server/config node packages/scripts/dist/dbt/generateDocs.js",
    "dbt-check-todos": "npm run --workspace scripts build && NODE_CONFIG_DIR=packages/central-server/config node packages/scripts/dist/dbt/checkTodos.js",
    "e2e-test": "npm run --workspace @tamanu/e2e-tests test",
    "e2e-show-report": "npm run --workspace @tamanu/e2e-tests show-report",
    "synthetic-test:facility": "turbo build --filter=@tamanu/synthetic-tests... && npm run --workspace @tamanu/synthetic-tests test:facility",
    "synthetic-test:central": "turbo build --filter=@tamanu/synthetic-tests... && npm run --workspace @tamanu/synthetic-tests test:central"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/api-client",
      "packages/build-tooling",
      "packages/central-server",
      "packages/constants",
      "packages/database",
      "packages/e2e-tests",
      "packages/errors",
      "packages/facility-server",
      "packages/fake-data",
      "packages/mobile",
      "packages/scripts",
      "packages/settings",
      "packages/shared",
      "packages/upgrade",
      "packages/utils",
      "packages/web",
      "packages/patient-portal",
      "packages/ui-components",
      "packages/synthetic-tests"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^8.55.0",
    "@playwright/test": "1.59.1",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^13.24.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.18",
    "typescript": "^5.8.0",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "node": "^24.13.0",
    "patch-package": "^8.0.0"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "fast-xml-parser": "^5.8.0",
    "protobufjs": "^7.6.4",
    "socket.io-parser": ">=4.2.6",
    "axios": "^1.18.0",
    "esbuild": "^0.28.1",
    "ms": "^2.1.3",
    "react": "18.2.0",
    "react-native-svg": "^12.1.0",
    "react-redux": "8.0.2",
    "react-dom": "18.2.0",
    "react-test-renderer": "^18.3.1",
    "@react-pdf/renderer": "^3.4.4",
    "@react-pdf/layout": "3.11.5",
    "@mui/material": "~6.1.1",
    "@mui/system": "~6.1.1",
    "@mui/icons-material": "~6.1.1",
    "@mui/styled-engine": "~6.1.1",
    "@mui/x-date-pickers": "~7.22.0"
  }
}
