# Windows VHDX experiment selector — read by the CD `config` job, which fans the
# values out to the windows-vhdx / windows-vhdx-direct jobs. Flip these per
# experiment and push; the job graph adapts.
#
#   VHDX_DIRECT_BUILD=false -> baseline-style: build from the linux image output
#     (needs the linux `images` job), then copy the finished tree into a VHDX.
#   VHDX_DIRECT_BUILD=true  -> build from source straight into a mounted VHDX,
#     running in parallel with the linux images (does NOT need them).
#
EXPERIMENT_VARIANT=direct-reduced-pruned
VHDX_FILESYSTEM=NTFS
VHDX_COMPRESS=false
VHDX_DIRECT_BUILD=true
VHDX_OPTIMIZE=false
VHDX_VIRTUAL_SIZE_MB=10240
