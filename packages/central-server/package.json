{
  "name": "@tamanu/central-server",
  "version": "2.59.0",
  "private": true,
  "description": "Central server for Tamanu",
  "homepage": "https://github.com/beyondessential/tamanu.git#readme",
  "repository": "git@github.com:beyondessential/tamanu.git",
  "author": "Beyond Essential Systems Pty. Ltd.",
  "license": "GPL-3.0-or-later AND BUSL-1.1",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "pkg": {
    "assets": [
      "config",
      "node_modules/config"
    ]
  },
  "scripts": {
    "build": "swc --out-dir dist --copy-files --source-maps true app",
    "clean-build": "npm run clean && npm run build",
    "build-watch": "npm run build -- --watch",
    "clean": "rimraf -- dist __disttests__",
    "clean:deps": "rimraf -- node_modules",
    "setup-dev": "node dist setup",
    "shell": "npm run build && node dist shell",
    "start-dev": "concurrently npm:build-watch npm:start-watch",
    "start-dev:test": "NODE_ENV=test concurrently npm:build-watch npm:start-watch",
    "start-watch": "sleep 1 && nodemon --delay 1 \"dist/**/*.js\"",
    "start": "node dist",
    "test": "npm run test-build && NODE_ENV=test jest",
    "test-build": "swc --delete-dir-on-start --out-dir __disttests__ --copy-files --source-maps true __tests__",
    "test-watch": "npm run test -- --watch"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/jest": "^0.2.26",
    "@tamanu/build-tooling": "*",
    "@tamanu/fake-data": "*",
    "@types/node-telegram-bot-api": "^0.64.6",
    "concurrently": "^9.2.1",
    "chai": "^4.1.2",
    "fast-check": "^3.3.0",
    "jest": "^29.3.1",
    "jest-expect-message": "^1.1.3",
    "jest-extended": "^2.0.0",
    "qs": "^6.15.2",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.4",
    "wait-for-expect": "^3.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.49.0",
    "@bgotink/kdl": "^0.1.6",
    "@bugsnag/js": "^7.22.4",
    "@bugsnag/plugin-express": "^7.19.0",
    "@casl/ability": "^6.8.0",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.42",
    "@opentelemetry/api": "^1.9.0",
    "@react-pdf/renderer": "^3.4.4",
    "@socket.io/postgres-adapter": "^0.3.1",
    "@tamanu/api-client": "*",
    "@tamanu/constants": "*",
    "@tamanu/database": "*",
    "@tamanu/errors": "*",
    "@tamanu/settings": "*",
    "@tamanu/shared": "*",
    "@tamanu/upgrade": "*",
    "@tamanu/utils": "*",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.18.3",
    "case": "^1.6.3",
    "chance": "^1.1.8",
    "check-disk-space": "^3.1.0",
    "cli-table3": "^0.6.2",
    "commander": "^9.0.0",
    "compression": "^1.7.2",
    "config": "^3.3.9",
    "date-fns": "^2.25.0",
    "date-fns-tz": "^1.3.6",
    "decimal.js": "^10.4.3",
    "excel-date-to-js": "^1.0.6",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-session": "^1.18.1",
    "express-validator": "^6.5.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "inflection": "^1.13.2",
    "jose": "^5.1.1",
    "json5": "^2.2.3",
    "jszip": "^3.7.1",
    "lodash": "^4.17.21",
    "mailgun.js": "^13.0.0",
    "mathjs": "^9.3.0",
    "mkdirp": "^1.0.4",
    "morgan": "^1.9.0",
    "ms": "^2.1.3",
    "nanoid": "^3.3.8",
    "node-cache": "^5.1.2",
    "node-telegram-bot-api": "^0.65.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.5.1",
    "prompts": "^2.0.0",
    "qrcode": "^1.5.0",
    "react": "16.8.5",
    "read": "^1.0.7",
    "semver": "^7.7.4",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "timesimp": "^1.0.2",
    "tiny-async-pool": "^1.2.0",
    "undici": "^7.5.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
