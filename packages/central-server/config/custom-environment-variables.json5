{
  "db": {
    "name": "CONFIG_SYNC_DB_NAME",
    "username": "CONFIG_SYNC_DB_USERNAME",
    "password": "CONFIG_SYNC_DB_PASSWORD",
    "host": "CONFIG_SYNC_DB_HOST",
    "port": "CONFIG_SYNC_DB_PORT",
    "verbose": "CONFIG_SYNC_DB_VERBOSE"
  },
  // local_system_secrets encryption is mandatory, so the key file must resolve
  // wherever the server boots. Deploys mount it and set CRYPTO_KEY_FILE.
  "crypto": {
    "keyFile": "CRYPTO_KEY_FILE"
  }
}
