{
  "db": {
    "name": "tamanu-central-generate",
    "migrateOnStartup": true,
    "verbose": false
  },
  "log": {
    "consoleLevel": "info"
  },
  "localisation": {
    "data": {
      "timeZone": "UTC",
      "country": {
        "name": "New Zealand",
        "alpha-2": "NZ",
        "alpha-3": "NZL"
      }
    }
  },
  "integrations": {
    "fhir": {
      "enabled": true, // the HTTP routes
      "worker": {
        "enabled": true
      }
    }
  },
  "primaryTimeZone": "Pacific/Auckland"
}
