  "paths": {
    "/Patient": {
      "get": {
        "description": "List all patients",
        "responses": {}
      }
    },
    "/DiagnosticReport": {
      "get": {
        "tags": [
          "DiagnosticReport"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "example": "final",
            "description": "The status of the report"
          },
          {
            "name": "subject:identifier",
            "in": "query",
            "required": true,
            "description": "Get results for patient with Application permit Id See HL7 FHIR Specs about Business Identifiers and token for more information"
          },
          {
            "name": "_sort",
            "required": true,
            "in": "query",
            "example": "-issued",
            "description": "Specify one or more other parameters to use as the sort order"
          },
          {
            "name": "_page",
            "required": true,
            "in": "query",
            "description": "Which page for pagination"
          },
          {
            "name": "_count",
            "in": "query",
            "description": "Number of records to return"
          },
          {
            "name": "_include",
            "in": "query",
            "description": "Additional resources to return - other resources that matching resources refer to"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/DiagnosticReport"
              }
            }
          }
        }
      }
    }
  }
