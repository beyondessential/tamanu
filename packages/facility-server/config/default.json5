{
  errors: {
    // enable to send errors to a bug tracking service
    enabled: false,
    // right now the only supported service is bugsnag
    type: 'bugsnag',
    // paste your bugsnag API key here
    apiKey: '',
  },
  "sync": {
    "schedule": "*/1 * * * *",
    "host": "https://central.main.cd.tamanu.app",
    "email": "",
    "password": "",
    "timeout": 10000,
    "syncApiConnection": {
      "host": "http://localhost",
      "port": 4100,
    },
    "persistedCacheBatchSize": 10000,
    "pauseBetweenPersistedCacheBatchesInMilliseconds": 50,
    "pauseBetweenCacheBatchInMilliseconds": 50,
    "persistUpdateWorkerPoolSize": 5,
    "assertIfPulledRecordsUpdatedAfterPushSnapshot": true,
    "enabled": true,
    "jitterTime": "1s",
    "backoff": {
      "multiplierMs": 300,
      "maxAttempts": 15,
      "maxWaitMs": 10000
    },
    "dynamicLimiter": {
      "initialLimit": 10, // start relatively low then grow upward
      "minLimit": 1,
      "maxLimit": 10000,
      "optimalTimePerPageMs": 2000, // aim for 2 seconds per page
      "maxLimitChangePerPage": 0.2 // max 20% increase/decrease from page to page
    }
  },
  "port": 4000,
  "deviceId": null,
  "db": {
    "name": "tamanu-facility",
    "username": "",
    "password": "",
    "verbose": false,
    "skipVersionCompatibilityCheck": false,
    "reportSchemas": {
      "enabled": false,
      "connections": {
        "raw": {
          "pool": {
            "max": 5
          },
          "username": "",
          "password": ""
        },
        "reporting": {
          "pool": {
            "max": 5
          },
          "username": "",
          "password": ""
        }
      }
    }
  },
  "metaServer": {
    "hosts": [
      "https://meta.tamanu.app",
    ],
    "serverId": null,
    "timeoutMs": 20000,
  },
  "integrations": {
    "fhir": {
      "enabled": false, // the HTTP routes
      "worker": {
        "enabled": false, // the materialisation worker
      },
    },
  },
  "auth": {
    "saltRounds": 12,
    "tokenDuration": "1h",
    "useHardcodedPermissions": true,

    // Authentication "cookie" secret. Set to a random value so sessions don't
    // expire when the server restarts.
    // "secret": "some long secret value",
  },
  "serverFacilityId": null,
  "serverFacilityIds": null,
  "schedules": {
    "refreshMaterializedView": {
      "upcomingVaccinations": {
        // every 10 mins
        "schedule": "*/10 * * * *"
      },
    },
    "fhirMissingResources": {
      "enabled": false,
      "schedule": "48 1 * * *" // once a day (better in off hours)
    },
    "sendStatusToMetaServer": {
      "enabled": true,
      // every minute
      "schedule": "* * * * *",
      jitterTime: "30s",
    },
    "timeSync": {
      "enabled": false,
      // every hour
      "schedule": "0 * * * *",
    },
    "mSupplyMedIntegrationProcessor": {
      "enabled": false,
      "schedule": "0 2 * * *",
      "batchSize": 100,
      "batchSleepAsyncDurationInMilliseconds": 50
    },
    "mSupplyStockOnHandProcessor": {
      "enabled": false,
      // every hour
      "schedule": "0 * * * *",
    },
  },
  "rateLimit": {
    // Set `enabled: false` to disable express-rate-limit entirely.
    // Rate limit counters key off `req.ip` and therefore respect the
    // `proxy.trusted` setting below.
    "enabled": true,
    // Permissive global limit applied to every request as a DoS backstop.
    "global": {
      // window in milliseconds
      "windowMs": 60000,
      // maximum requests per window per IP
      "max": 600
    },
    // Stricter limit applied to unauthenticated / expensive endpoints
    // (login, refresh, setFacility, password reset). Successful requests
    // are not counted, so only failed/abusive traffic accumulates toward
    // this limit.
    "auth": {
      "windowMs": 900000,
      "max": 30
    }
  },
  // IANA tzdata timezone for all stored datetimes.
  // Either "primaryTimeZone" or "countryTimeZone" may be used; primaryTimeZone takes precedence.
  // @see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
  "primaryTimeZone": null,
  "countryTimeZone": "Australia/Melbourne",
  "canonicalHostName": "http://localhost:4000",
}
