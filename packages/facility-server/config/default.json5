{
  errors: {
    // enable to send errors to a bug tracking service
    enabled: false,
    // right now the only supported service is bugsnag
    type: 'bugsnag',
    // paste your bugsnag API key here
    apiKey: '',
  },
  "sync": {
    "schedule": "*/1 * * * *",
    // Sync host + credentials are now resolved from local system facts, set via
    // the SYNC_URL env var or the first-run setup wizard. These config keys are
    // a deprecated fallback (one backwards-compatible version) — leave empty to
    // use SYNC_URL / the wizard.
    "host": "",
    "email": "",
    "password": "",
    "timeout": 10000,
    "syncApiConnection": {
      "host": "http://localhost",
      "port": 4100,
    },
    "persistedCacheBatchSize": 10000,
    "pauseBetweenPersistedCacheBatchesInMilliseconds": 50,
    "pauseBetweenCacheBatchInMilliseconds": 50,
    "persistUpdateWorkerPoolSize": 5,
    "assertIfPulledRecordsUpdatedAfterPushSnapshot": true,
    "enabled": true,
    "jitterTime": "1s",
    "backoff": {
      "multiplierMs": 300,
      "maxAttempts": 15,
      "maxWaitMs": 10000
    },
    "dynamicLimiter": {
      "initialLimit": 10, // start relatively low then grow upward
      "minLimit": 1,
      "maxLimit": 10000,
      "optimalTimePerPageMs": 2000, // aim for 2 seconds per page
      "maxLimitChangePerPage": 0.2 // max 20% increase/decrease from page to page
    }
  },
  "port": 4000,
  "deviceId": null,
  "db": {
    // Set the DATABASE_URL env var to a connection string to supply
    // name/username/password/host/port and any Sequelize pool params in its query
    // string (e.g. ?max=10&min=2&idle=10000). Leave unset to use the structured
    // fields below.
    "name": "tamanu-facility",
    "username": "",
    "password": "",
    "verbose": false,
  },
  "metaServer": {
    "hosts": [
      "https://meta.tamanu.app",
    ],
    "serverId": null,
    "timeoutMs": 20000,
  },
  "integrations": {
    "fhir": {
      "enabled": false, // the HTTP routes
      "worker": {
        "enabled": false, // the materialisation worker
      },
    },
    "mSupplyMed": {
      "enabled": false,
      "username": "",
      "password": ""
    },
    "ips": {
      "attester": "Ministry of Health",
      "author": "Tamanu is a free and open-source EHR for low resource and remote settings.",
      "email": {
        "subject": "Your International Patient Summary",
        "bodyText": "Please scan the QR code attached to view your International Patient Summary",
      },
    },
  },
  "auth": {
    "saltRounds": 12,
    "tokenDuration": "1h",
    "useHardcodedPermissions": true,

    // Authentication "cookie" secret. Set to a random value so sessions don't
    // expire when the server restarts.
    // "secret": "some long secret value",
  },
  "serverFacilityId": null,
  "serverFacilityIds": null,
  "schedules": {
    "refreshMaterializedView": {
      "upcomingVaccinations": {
        // every 10 mins
        "schedule": "*/10 * * * *"
      },
    },
    "bedFeeCharger": {
      // hourly; recompute is idempotent so a new night lands within an hour of each
      // facility's local overnight-check time
      "schedule": "0 * * * *",
      "batchSize": 100,
      "batchSleepAsyncDurationInMilliseconds": 50
    },
    "fhirMissingResources": {
      "enabled": false,
      "schedule": "48 1 * * *" // once a day (better in off hours)
    },
    "sendStatusToMetaServer": {
      "enabled": true,
      // every minute
      "schedule": "* * * * *",
      jitterTime: "30s",
    },
    "timeSync": {
      "enabled": false,
      // every hour
      "schedule": "0 * * * *",
    },
    "mSupplyMedIntegrationProcessor": {
      "enabled": false,
      "schedule": "0 2 * * *",
      "batchSize": 100,
      "batchSleepAsyncDurationInMilliseconds": 50
    },
    "mSupplyStockOnHandProcessor": {
      "enabled": false,
      // every hour
      "schedule": "0 * * * *",
    },
  },
  "rateLimit": {
    // Set `enabled: false` to disable express-rate-limit entirely.
    // Rate limit counters key off `req.ip` and therefore respect the
    // `proxy.trusted` setting below.
    "enabled": true,
    // Permissive global limit applied to every request as a DoS backstop.
    "global": {
      // window in milliseconds
      "windowMs": 60000,
      // maximum requests per window per IP
      "max": 600
    },
    // Stricter limit applied to unauthenticated / expensive endpoints
    // (login, refresh, setFacility, password reset). Successful requests
    // are not counted, so only failed/abusive traffic accumulates toward
    // this limit.
    "auth": {
      "windowMs": 900000,
      "max": 30
    }
  },
  "tasking": {
    "upcomingTasksTimeFrame": 8, // hours,
    "upcomingTasksShouldBeGeneratedTimeFrame": 72, // hours
  },
  "medicationAdministrationRecord": {
    "upcomingRecordsShouldBeGeneratedTimeFrame": 72, // hours
  },
  "crypto": {
    // Encryption key for local_system_secrets (encryption is mandatory).
    // This committed key is for local dev/test ONLY; deploys override it via
    // the CRYPTO_KEY_FILE env var pointing at a mounted secret.
    "keyFile": "config/dev-secret.key"
  },
  "language": "en",
  "canonicalHostName": "http://localhost:4000",
}
