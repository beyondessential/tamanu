{
  "db": {
    "name": "tamanu-database-test",
    "migrateOnStartup": true,
    "sqlitePath": "/tmp/tamanu-database-src-tests.db",
    "testMode": true,
    "verbose": false
  },
  "log": {
    "consoleLevel": "none"
  },
  "sync": {
    "persistedCacheBatchSize": 10000,
    "persistUpdateWorkerPoolSize": 5,
    "pauseBetweenPersistedCacheBatchesInMilliseconds": 50
  },
  "primaryTimeZone": "Australia/Melbourne",
  "serverFacilityIds": ["facility-1"],
  "integrations": {
    "fhir": {
      "enabled": false,
      "worker": {
        "enabled": true,
        "concurrency": 10,
        "resourceMaterialisationEnabled": {
          "Patient": true,
          "Encounter": false,
          "Immunization": false,
          "MediciReport": false,
          "Organization": false,
          "Practitioner": false,
          "ServiceRequest": false,
          "Specimen": false,
          "MedicationRequest": false
        }
      },
      "parameters": {
        "_count": {
          "default": 100,
          "max": 1000
        }
      },
      "extensions": {
        "Patient": {
          "newZealandEthnicity": false
        }
      }
    }
  }
}
